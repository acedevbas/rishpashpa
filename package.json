{
  "name": "rishpashpa",
  "version": "1.0.0",
  "description": "Telegram mini app reminder for exercises",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.js --bundle --outfile=public/app.js --platform=browser --target=es2017 --loader:.js=jsx --external:react --external:react-dom/client --format=esm",
    "start": "npm run build && node scripts/inject-env.mjs && node server.js",
    "test": "echo 'no tests' && exit 0"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "node-telegram-bot-api": "^0.66.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.8"
  }
}
